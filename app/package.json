{
  "name": "tome-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:serve": "npm run build && npm run deploy",
    "deploy": "rm -rf ../server/public_app && mkdir -p ../server/public_app && cp -r dist/* ../server/public_app/",
    "watch": "npm run build -- --watch && npm run deploy",
    "watch:deploy": "chokidar 'src/**/*' -c 'npm run build:serve'",
    "preview": "vite preview",
    "lint": "eslint --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix --ignore-path .gitignore ."
  },
  "dependencies": {
    "@mdi/font": "^7.4.0",
    "apexcharts": "^5.10.0",
    "firebase": "^10.0.0",
    "jwt-decode": "^4.0.0",
    "moment": "^2.29.4",
    "pinia": "^2.1.0",
    "register-service-worker": "^1.7.2",
    "vue": "^3.4.0",
    "vue-cal": "^4.10.0",
    "vue-router": "^4.3.0",
    "vue3-apexcharts": "^1.11.1",
    "vuetify": "^3.5.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@vitejs/plugin-vue": "^5.0.4",
    "@vue/eslint-config-typescript": "^13.0.0",
    "chokidar-cli": "^3.0.0",
    "eslint": "^8.57.0",
    "eslint-plugin-vue": "^9.25.0",
    "sass": "^1.75.0",
    "typescript": "^5.4.0",
    "vite": "^5.2.0",
    "vue-tsc": "^2.0.0"
  }
}
